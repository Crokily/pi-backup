# Required
DISCORD_BOT_TOKEN=

# Trigger behavior
# DM_POLICY: pairing | allowlist | open | disabled
DM_POLICY=pairing
REQUIRE_MENTION=true

# Comma-separated Discord user IDs with admin privileges (approve pairing, etc.)
ADMIN_USER_IDS=

# Comma-separated guild/channel allowlists (optional)
ALLOWED_GUILD_IDS=
ALLOWED_CHANNEL_IDS=

# Session/history
HISTORY_MAX_TURNS=12
SQLITE_PATH=./discord_agent.db
SYSTEM_PROMPT=You are a helpful coding and research assistant.

# Backend mode: pi | openai | command
BACKEND_MODE=pi

# --- Native pi backend ---
PI_BIN=pi
# Optional: fixed model/thinking defaults for pi backend
PI_MODEL=openai-codex/gpt-5.3-codex
PI_THINKING=medium
# Backward-compatible aliases also supported by code:
# PI_MODEL_DEFAULT=
# PI_THINKING_DEFAULT=

# --- OpenAI-compatible backend ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Command backend ---
# Command reads user message from stdin, prints assistant response to stdout
AGENT_COMMAND=python3 -c "import sys;print('Echo:',sys.stdin.read().strip())"

# Research mode (web search)
RESEARCH_ENABLED=true
WEB_SEARCH_BIN=/home/ubuntu/.pi/agent/bin/web-search
RESEARCH_MAX_RESULTS=5
RESEARCH_READABLE_SOURCES=2
RESEARCH_PAGE_CHAR_LIMIT=3500

# Report web layer (for long/complex markdown outputs)
REPORT_SERVER_ENABLED=true
# If using Nginx/Caddy reverse proxy, prefer 127.0.0.1
REPORT_BIND=127.0.0.1
REPORT_PORT=18080
# Preferred: set one public entry URL (domain or public ip)
# Example: REPORT_BASE_URL=https://docs.a2a.ing
REPORT_BASE_URL=
# Optional fallback host when REPORT_BASE_URL is empty (e.g. 1.2.3.4 or report.example.com)
# Example: REPORT_PUBLIC_HOST=docs.a2a.ing
REPORT_PUBLIC_HOST=
REPORT_DIR=/home/ubuntu/discord-agent/web-reports
REPORT_AUTO_FOR_RESEARCH=true
REPORT_AUTO_MIN_CHARS=1800

# Heartbeat framework (unified scheduled tasks)
HEARTBEAT_DEFAULT_ENABLED=false
HEARTBEAT_POLL_SECONDS=45
HEARTBEAT_TASK_TIMEOUT_SEC=240
HEARTBEAT_MAX_TASKS_PER_TICK=3
HEARTBEAT_DEFAULT_MAX_ALERTS_PER_DAY=2
HEARTBEAT_DEFAULT_DEDUPE_WINDOW=6h

# Proactive restart report (DM to admins)
STARTUP_REPORT_ENABLED=true

# Async task queue (recommended for long-running work)
ASYNC_TASKS_ENABLED=true
ASYNC_TASK_WORKERS=2
ASYNC_TASK_POLL_SECONDS=2
ASYNC_TASK_TIMEOUT_SEC=1800
ASYNC_TASK_MAX_ATTEMPTS=2

# Advanced
MAX_REPLY_CHARS=1900
